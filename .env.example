# praam-platform — copy to ~/.praam/secrets.env (never commit real keys)
#
# This is the ONLY env file for this repo. LiteLLM and platform-config read it.
# Override path: export PRAAM_SECRETS_FILE=/path/to/secrets.env
#
# Suite apps do NOT copy this file — they only need at startup:
#   PRAAM_CONFIG_URL=http://127.0.0.1:3180
#   PRAAM_SERVICE_TOKEN=praam-platform-dev
# See docs/CONFIG_API.md

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Config API auth (dev default — change in shared environments)
# PRAAM_SERVICE_TOKEN=praam-platform-dev
